# 如果使用自定义配置文件，请确保 [save_variables] 位于 [ace] 之上
[save_variables]
filename: ~/vars.cfg

[respond]

[ace]
serial: /dev/serial/by-id/usb-ANYCUBIC_ACE_1-if00
baud: 115200
# 禁用日志记录，默认 True
#disable_logging: True
#log_dir: ~/printer_data/logs
# 日志级别：DEBUG - 调试信息，INFO - 主要事件，WARNING - 警告，ERROR - 错误
# Logging levels: DEBUG - for debugging info, INFO - for main events, WARNING - for warnings, ERROR - for errors
#log_level: DEBUG
# 最大日志大小（Mb）
#max_log_size: 10
# 旧日志数量
#log_backup_count: 3
# 串口超时设置
# response_timeout: 2.0
# read_timeout: 0.1
# write_timeout: 0.5
# 最大队列大小，默认 20 条消息
max_queue_size: 20
# 默认送料速度，出厂默认范围为 10-25
feed_speed: 25
# 默认退料速度，出厂默认范围为 10-25
retract_speed: 25
# 换色/换刀时的退料长度
toolchange_retract_length: 100
# 喷头碰触计数（用于确认停车位置），默认为 5。若设备在较低数值下运行稳定，可适当调低
park_hit_count: 5
# 烘干最高温度。~60℃ 理论上安全（尚未充分测试，请谨慎设置以免损坏设备）
max_dryer_temperature: 55
# 换刀后禁用辅助送料功能。默认为 true
disable_assist_after_toolchange: True


[gcode_macro _ACE_PRE_TOOLCHANGE]
gcode:
    # 空操作
    # M117 准备更换耗材
    # Preparation for filament change
    M117 Preparation for filament change
    {% set T = 220 %}
    {% if printer.extruder.target != 0 %} # 如果有挤出机设定温度
        {% if printer.extruder.temperature < printer.extruder.target %} # 如果未达到，加热
#            M118 Heating from {printer.extruder.temperature} to {printer.extruder.target}.
            SET_HEATER_TEMPERATURE HEATER=extruder TARGET={printer.extruder.target|float}
            TEMPERATURE_WAIT SENSOR=extruder MINIMUM={printer.extruder.target|float} 
        {% endif %}
    {% else %} # 如果没有挤出机设定温度
        {% if printer.extruder.target < T %}  # 加热到 T.
#            M118 No setpoint, heating to {T}.
            SET_HEATER_TEMPERATURE HEATER=extruder TARGET={T}
            TEMPERATURE_WAIT SENSOR=extruder MINIMUM={T}
        {% endif %}
    {% endif %}
    {% if "xyz" not in printer.toolhead.homed_axes %}
        G28
        SAVE_GCODE_STATE NAME=FILAMENT_CHANGE_STATE
    {% else %}
        SAVE_GCODE_STATE NAME=FILAMENT_CHANGE_STATE
    {% endif %}
    {% if params.FROM is defined %}
        {% set from_index = params.FROM|int %}
        {% if from_index != -1 %}
            # 保存指定的料槽
            # Save the selected slot
            #{% set from_index = params.FROM|int %}
            # 报告停车开始
            # Report the start of parking
            # M118 料槽 {from_index} 的送料已关闭.
            M118 Feed disabled for slot {from_index}

            # 启动指定料槽的停车
            # Start parking the selected slot
	        ACE_DISABLE_FEED_ASSIST INDEX={from_index}
        {% endif %}
    {% else %}
        # 如果未指定料槽，则报错
        # If slot is not specified, report an error
        {action_respond_info("Index is lost")}
        RESPOND TYPE=error MSG="Error INDEX is lost"
    {% endif %}
#   切断耗材    
    {% set max_z = printer.toolhead.axis_maximum.z|float %}
    {% set act_z = printer.toolhead.position.z|float %}
    {% if act_z < (max_z - 5.0) %}
        {% set Z = 5.0 %}
    {% else %}
        {% set Z = max_z - act_z %}
    {% endif %}
    G91                        ; relative for safe Z lift
    G1 Z{Z}                    ; safe lifting
    G90                         ; absolute for parking
    {% if from_index != -1 %}
        G1 X{245} Y{0} F7800    ; parking to knife place 
    {% endif %}       
#   移动到清洁区
#   Move to cleaning zone
    G1 X-8 Y0 F7800
    G91
    {% if from_index != -1 %}
        G1 E-70 F300
    {% endif %}
    G90

[gcode_macro _ACE_POST_TOOLCHANGE]
gcode:
    # 空操作
    M117 耗材更换后处理
    # Actions after filament change
    {% if params.TO is defined %}
        # 保存指定的料槽
        # Save the selected slot
        {% set to_index = params.TO|int %}
        {% if to_index != -1 %}
            G91
            G1 E100 F300
            G90
            G1 X5 Y0 F7800
            G1 X-8 Y0 F7800
        {% endif %}
    {% else %}
        # 如果未指定料槽，则报错
        # If slot is not specified, report an error
        {action_respond_info("Index is lost")}
        RESPOND TYPE=error MSG="Error INDEX is lost"
    {% endif %}

    {% if to_index != -1 %}

        # 报告停车开始
        # Report the start of parking
        # M118 料槽 {to_index} 的送料已启用.
        M118 Feed enabled for slot {to_index}

        # 启动指定料槽的停车
        # Start parking the selected slot
	    ACE_ENABLE_FEED_ASSIST INDEX={to_index}
    {% endif %}
    
    RESTORE_GCODE_STATE NAME=FILAMENT_CHANGE_STATE MOVE=1 MOVE_SPEED=1500

[gcode_macro _ACE_ON_EMPTY_ERROR]
gcode:
    {action_respond_info("Spool is empty")}
    {% if printer.idle_timeout.state == "Printing" %}
        PAUSE
    {% endif %}

[gcode_macro ENABLE_FEED_ASSIST]
gcode:
    # 检查是否指定了料槽
    # Check if slot is specified
    {% if params.INDEX is defined %}
        # 保存指定的料槽
        # Save the selected slot
        {% set target_index = params.INDEX|int %}
         # 报告停车开始
         # Report the start of parking
        # M118 料槽 {target_index} 的送料已启用.
        M118 Feed enabled for slot {target_index}

        # 启动指定料槽的停车
        # Start parking the selected slot
	    ACE_ENABLE_FEED_ASSIST INDEX={target_index}

    {% else %}
        # 如果未指定料槽，则报错
        # If slot is not specified, report an error
        {action_respond_info("Index is lost")}
        RESPOND TYPE=error MSG="Error INDEX is lost"
    {% endif %}


[gcode_macro DISABLE_FEED_ASSIST]
gcode:
    # 检查是否指定了料槽
    # Check if slot is specified
    {% if params.INDEX is defined %}
        # 保存指定的料槽
        # Save the selected slot
        {% set target_index = params.INDEX|int %}
         # 报告停车开始
         # Report the start of parking
        M118 料槽 {target_index} 的送料已关闭.

        # 启动指定料槽的停车
        # Start parking the selected slot
	    ACE_DISABLE_FEED_ASSIST INDEX={target_index}

    {% else %}
        # 如果未指定料槽，则报错并依次禁用所有料槽的辅助送料
        # If slot is not specified, report an error and disable assist for all slots in sequence
        {action_respond_info("Index is lost")}
        ACE_DISABLE_FEED_ASSIST INDEX=0
        G4 P1000
        ACE_DISABLE_FEED_ASSIST INDEX=1
        G4 P1000
        ACE_DISABLE_FEED_ASSIST INDEX=2
        G4 P1000
        ACE_DISABLE_FEED_ASSIST INDEX=3
        G4 P1000
    {% endif %}

[gcode_macro PARK_TO_TOOLHEAD]
gcode:
    # 检查是否指定了料槽
    # Check if slot is specified
    {% if params.INDEX is defined %}
        # 保存指定的料槽
        # Save the selected slot
        {% set target_index = params.INDEX|int %}
          # 报告停车开始
         # Report the start of parking
        # M118 已开始料槽 {target_index} 的喷头停车
        M118 Started parking filament for slot {target_index}

        # 启动指定料槽的停车
        # Start parking the selected slot
	    ACE_PARK_TO_TOOLHEAD INDEX={target_index}

    {% else %}
        # 如果未指定料槽，则报错
        # If slot is not specified, report an error
        {action_respond_info("Index is lost")}
        RESPOND TYPE=error MSG="Error INDEX is lost"
    {% endif %}
	
   

[gcode_macro START_DRYING]
gcode:
    # 检查是否指定了温度
    {% if params.TEMP is defined %}
        # 保存指定的温度
        {% set target_temp = params.TEMP|int %}
    {% else %}
        # 如果未指定温度，则使用默认值（55℃）
        # If temperature is not specified, use default value (e.g., 55 degrees)
        {% set target_temp = 55 %}
    {% endif %}
	# 检查是否指定了时间
	# Check if time is specified
    {% if params.TIME is defined %}
         # 保存指定的时间（分钟）
        {% set target_time = params.TIME|int %}
    {% else %}
        # 如果未指定时间，则使用默认值（120分钟）
        # If time is not specified, use default value (e.g., 120 minutes)
        {% set target_time = 120 %}
    {% endif %}
	
    # 报告烘干开始
    # Report the start of drying
    M117 耗材烘干已启动，温度 {target_temp}°C，时长 {target_time} 分钟

     # 执行带参烘干指令
	ACE_START_DRYING TEMP={target_temp} DURATION={target_time}

[gcode_macro STOP_DRYING]
gcode: 
    ACE_STOP_DRYING
    M118 耗材烘干已停止。风扇将继续运行直至加热器完全冷却。
    
[gcode_macro TR]
gcode:
    ACE_CHANGE_TOOL TOOL=-1
    
[gcode_macro T0]
gcode:
    ACE_CHANGE_TOOL TOOL=0

[gcode_macro T1]
gcode:
    ACE_CHANGE_TOOL TOOL=1

[gcode_macro T2]
gcode:
    ACE_CHANGE_TOOL TOOL=2

[gcode_macro T3]
gcode:
    ACE_CHANGE_TOOL TOOL=3

# 无限料盘宏

[gcode_macro SET_INFINITY_SPOOL_ORDER]
gcode:
    # 设置无限料盘模式的料槽切换顺序
    # Set slot order for infinity spool mode
    # 使用方法 / Usage: SET_INFINITY_SPOOL_ORDER ORDER="0,1,2,3"
    # 对于空料槽使用 'none' / Use 'none' for empty slots: ORDER="0,1,none,3"
    {% if params.ORDER is defined %}
        {% set order = params.ORDER|string %}
        ACE_SET_INFINITY_SPOOL_ORDER ORDER={order}
    {% else %}
        {action_respond_info("ORDER parameter is required")}
        RESPOND TYPE=error MSG="Error: ORDER parameter is required"
        RESPOND MSG="Usage: SET_INFINITY_SPOOL_ORDER ORDER=\"0,1,2,3\""
        RESPOND MSG="Use 'none' for empty slots: ORDER=\"0,1,none,3\""
    {% endif %}

[gcode_macro RESET_INFINITY_SPOOL]
gcode:
    # 重置无限料盘位置（从头开始）
    # Reset infinity spool position (start from beginning)
    SAVE_VARIABLE VARIABLE=ace_infsp_position VALUE=0
    {action_respond_info("Infinity spool position reset to start")}

[gcode_macro _ACE_PRE_INFINITYSPOOL]
gcode:
    # 在无限料盘模式下更换料盘前执行的宏
    # Macro executed before spool change in infinity spool mode
    # 默认无操作，根据需要自定义
    M117 Infinity Spool: Changing spool

[gcode_macro _ACE_POST_INFINITYSPOOL]
gcode:
    # 在无限料盘模式下更换料盘后执行的宏
    # Macro executed after spool change in infinity spool mode
    # 默认无操作，根据需要自定义
    M117 Infinity Spool: Spool changed

# ACE 设备的温度传感器
# Temperature sensor for ACE device
# 此传感器从 ACE 模块状态读取温度
# This sensor reads temperature from the ACE module status
# 注意：模块必须安装在 klippy/extras/temperature_ace.py 中
# NOTE: The module must be installed in klippy/extras/temperature_ace.py
# 首先加载 temperature_ace 模块（注册传感器工厂）
# First, load the temperature_ace module (registers the sensor factory)
[temperature_ace]

# 然后将其用作温度传感器
# Then use it as a temperature sensor
[temperature_sensor ValgAce]
sensor_type: temperature_ace
# 可选：最低温度（默认：0）
# Optional: minimum temperature (default: 0)
#min_temp: 0
# 可选：最高温度（默认：100）
# Optional: maximum temperature (default: 100)
#max_temp: 100
